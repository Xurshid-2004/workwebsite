# Supabase — set these to enable the real backend (otherwise mock/local data is used)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth provider: mock | supabase (supabase requires URL + anon key above)
NEXT_PUBLIC_AUTH_PROVIDER=mock

# Public site URL (SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional map providers
NEXT_PUBLIC_MAP_PROVIDER=placeholder

# ---------------------------------------------------------------------------
# Supabase setup (one-time)
# ---------------------------------------------------------------------------
# 1. Create a project at https://supabase.com
# 2. Copy Project URL + anon key into this file as .env.local
# 3. Run SQL migrations in Supabase SQL Editor (in order):
#    - supabase/migrations/001_schema.sql
#    - supabase/migrations/002_seed.sql
#    - supabase/migrations/003_admin.sql
#    - supabase/migrations/004_security_hardening.sql
# 4. Enable Realtime for the `messages` table (Database → Replication)
# 5. Set NEXT_PUBLIC_AUTH_PROVIDER=supabase and restart `npm run dev`

# ---------------------------------------------------------------------------
# Production deployment (Vercel / Node)
# ---------------------------------------------------------------------------
# NODE_ENV=production
# Set NEXT_PUBLIC_SITE_URL to your production domain
# Run: npm run build && npm run start
