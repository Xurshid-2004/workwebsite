DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Asia/Tashkent

# Production PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/jobmarket

CORS_ALLOWED_ORIGINS=http://localhost:3000,https://workwebsite-five.vercel.app
# CSRF_TRUSTED_ORIGINS defaults to CORS_ALLOWED_ORIGINS when unset.

DRF_PAGE_SIZE=24
DRF_ANON_RATE=300/hour
DRF_USER_RATE=2000/hour
DRF_AUTH_RATE=20/minute

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Production hardening (used when DJANGO_DEBUG=false)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
# DB_CONN_MAX_AGE=60
